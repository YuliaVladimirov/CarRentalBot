# Default: treat all text files correctly
* text=auto

# Enforce LF for source & config
*.java  text eol=lf
*.kt    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.xml   text eol=lf
*.sql   text eol=lf
*.md    text eol=lf
*.properties text eol=lf
*.html  text eol=lf

# Maven wrapper
/mvnw text eol=lf
*.cmd text eol=crlf
